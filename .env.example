# Copy to .env for local dev; set the same VITE_* vars in the Vercel project.
# This site shares the Swarnix Supabase project + n8n instance as the mobile
# swarnix-studio app. The anon key is public — it's safe in the browser ONLY
# because every app_* table has RLS keyed to auth.uid().

VITE_SUPABASE_URL=https://bigmdvjrvqyqzyrijdum.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudinary unsigned upload (same account the Swarnix web app uses). The site
# uploads device photos directly with this preset; n8n holds the secret creds.
VITE_CLOUDINARY_CLOUD=jewelleryinventory
VITE_CLOUDINARY_PRESET=jewelleryupload

# n8n instance (shared with Swarnix). Webhook paths are derived from this base.
VITE_N8N_BASE=https://n8n.srv1639765.hstgr.cloud/webhook
